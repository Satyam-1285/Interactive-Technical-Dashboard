    <script>
        // Real-time Clock Logic
        function updateUptime() {
            const now = new Date();
            document.getElementById('uptime').innerText = now.toLocaleTimeString();
        }
        setInterval(updateUptime, 1000);

        // Terminal Logging Logic
        function logData(message) {
            const consoleBox = document.getElementById('console');
            const timestamp = new Date().toLocaleTimeString().split(' ')[0];
            consoleBox.innerHTML += `<br>> [${timestamp}] ${message}`;
            consoleBox.scrollTop = consoleBox.scrollHeight;
        }

        // Random background "system noise"
        setInterval(() => {
            const messages = [
                "Voltage stable...",
                "ThingSpeak API pinged",
                "Arduino handshake successful",
                "Memory leak: 0%",
                "Circuit impedance: Optimal"
            ];
            if (Math.random() > 0.7) {
                logData(messages[Math.floor(Math.random() * messages.length)]);
            }
        }, 5000);
    </script>
